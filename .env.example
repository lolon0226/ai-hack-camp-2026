# 데모·디버그 (앱 동작)
DEMO_MODE=0
DEBUG_PANEL_ENABLED=0

# 본선 모드(보안·표시 정책 등 — 진료내역 재사용 시각 제한에는 사용하지 않음)
FINAL_MODE=1

# 고객 식별·진료내역 저장용 해시 시크릿(주민·전화 원문은 DB에 저장하지 않음)
REDRIBBON_SEARCH_HASH_SECRET=your_search_hash_secret

# CODEF — 데모 키 (CODEF_USE_DEMO=1 일 때 사용)
CODEF_USE_DEMO=1
CODEF_DEMO_CLIENT_ID=
CODEF_DEMO_CLIENT_SECRET=

# CODEF — 상용 키 (CODEF_USE_DEMO=0 일 때 사용)
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
# CODEF API 비밀번호 RSA 암호화용 공개키(base64 DER 또는 PEM)
CODEF_PUBLIC_KEY=your_codef_public_key

# CODEF API
CODEF_BASE_URL=https://development.codef.io
CODEF_HIRA_MEDICAL_PATH=/v1/kr/public/hw/hira-list/my-medical-information
# 신용정보원 내보험다보여 (기관코드 0001)
CREDIT4U_ORGANIZATION=0001
CODEF_CREDIT4U_CONTRACT_INFO_PATH=/v1/kr/insurance/0001/credit4u/contract-info
CODEF_CREDIT4U_REGISTER_PATH=/v1/kr/insurance/0001/credit4u/register
CREDIT4U_TIMEOUT=160
CREDIT4U_EMAIL_TIMEOUT=180
CREDIT4U_AUTH_METHOD=0
CREDIT4U_APPLICATION_TYPE=1
CREDIT4U_IDENTITY_ENC_YN=N

# 신용정보원 내보험다보여 (보험가입이력)
REDRIBBON_CREDIT4U_SECRET=your_credit4u_secret
# CREDIT4U_ID_PREFIX는 기본 rr 권장. 전체 ID는 6~12자여야 함.
CREDIT4U_ID_PREFIX=rr
